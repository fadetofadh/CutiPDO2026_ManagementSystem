<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_select_employee"
            android:textSize="16sp"
            android:textColor="#333333"/>

        <Spinner
            android:id="@+id/spEmployeeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_select_leave_dates"
            android:textSize="16sp"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etSelectedDates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:focusable="false"
            android:clickable="true"
            android:hint="@string/hint_select_date_range"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background_normal"/>

        <TextView
            android:id="@+id/tvTotalDaysDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="@string/duration_zero"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2D3748"
            android:background="#F7FAFC"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_leave_type"
            android:textSize="16sp"
            android:textColor="#333333"/>

        <Spinner
            android:id="@+id/spLeaveType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_reason_of_leaving"
            android:textSize="16sp"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etLeaveDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_description_input"
            android:gravity="top|start"
            android:hint="@string/hint_enter_reason"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:textColor="#333333"
            android:textColorHint="#999999" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="15dp">

            <Button
                android:id="@+id/btnAddToBatch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_add"
                android:backgroundTint="#1E88E5"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnReviewSubmit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_review"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnCancelPortal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel_completed"
            android:backgroundTint="#E53E3E"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
