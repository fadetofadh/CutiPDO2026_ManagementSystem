<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.tools.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".ReviewQueueActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_batch_requests"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:textColor="#333333"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_queue_hint"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:textColor="#666666"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="10dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReviewQueue"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="20dp"
        android:cacheColorHint="@android:color/transparent"
        android:scrollbars="vertical"/>

    <Button
        android:id="@+id/btnFinalSubmitAll"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/submit_all_to_supervisor_zero"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#008577"/>

</LinearLayout>