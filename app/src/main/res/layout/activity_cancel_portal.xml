<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CancelPortalActivity">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshCancel"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Content Wrapper with Padding -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/layoutHeaderCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <TextView
                    android:id="@+id/tvCancelTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/revoke_cancel_portal_title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <TextView
                    android:id="@+id/tvClearSelectionCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_clear_marks"
                    android:textColor="#E53E3E"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:padding="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCancelSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/layoutHeaderCancel"
                android:text="@string/cancel_portal_subtitle"
                android:textSize="12sp"
                android:gravity="start"
                android:textColor="#C53030"
                android:layout_marginBottom="20dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCancelHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/tvCancelSubtitle"
                android:layout_above="@id/btnBatchCancel"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btnBatchCancel"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_alignParentBottom="true"
                android:backgroundTint="#E53E3E"
                android:text="@string/btn_cancel_selected_count"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvNoHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/toast_no_approved_requests"
                android:textSize="16sp"
                android:gravity="center"
                android:textColor="#888888"
                android:layout_centerInParent="true"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/pbCancelLoader"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_centerInParent="true"
                android:indeterminate="true"
                android:visibility="visible"/>
        </RelativeLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Progress Overlay - Outside the padding to cover the WHOLE screen -->
    <FrameLayout
        android:id="@+id/progressOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:elevation="8dp">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/tvProgressMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/msg_processing"
                android:textColor="#333333"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>
