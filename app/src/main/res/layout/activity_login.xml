<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/tvCreditPlaceholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="488dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="30dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="250dp"
                android:layout_height="120dp"
                android:layout_marginBottom="24dp"
                android:src="@drawable/login_logo"
                android:contentDescription="App Logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:text="@string/portal_gateway"
                android:textColor="#333333"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:maxWidth="488dp"
                android:text="@string/select_your_role"
                android:textColor="#555555"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioGroupRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:gravity="center_horizontal"
                android:maxWidth="488dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbKadiv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="20dp"
                    android:checked="true"
                    android:text="@string/kadiv_head_div"
                    android:textColor="#555555"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/rbSpv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/spv_supervisor"
                    android:textColor="#555555"
                    android:textSize="15sp" />

            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="5dp"
                android:maxWidth="488dp"
                android:text="@string/system_passcode"
                android:textColor="#555555"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPasscode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="@string/hint_enter_password"
                android:maxWidth="488dp"
                android:textColorHint="#757575"
                android:autofillHints="password"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:layout_gravity="center_horizontal"
                android:minWidth="250dp"
                android:maxWidth="320dp"
                android:backgroundTint="#008577"
                android:text="@string/verify_enter"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCheckBalancePortal"
                android:layout_width="wrap_content"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center_horizontal"
                android:minWidth="250dp"
                android:maxWidth="320dp"
                android:backgroundTint="#4A5568"
                android:text="@string/btn_check_balance_portal"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tvCreditPlaceholder"
        android:layout_width="222dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="8dp"
        android:text="@string/placeholder_text"
        android:textColor="#555555"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
